# ==============================================
# Library Creator - Backend - Variables de Entorno
# ==============================================
# Copia este archivo a .env y completa con tus valores

# ==============================================
# CONFIGURACIÓN DE BASE DE DATOS
# ==============================================
DB_URL="jdbc:mysql://localhost:3306/libraryai_db"
DB_USER="root"
DB_PASSWD="tu_contraseña_segura_de_mysql"

# ==============================================
# SEGURIDAD - JWT (JSON Web Tokens)
# ==============================================
# IMPORTANTE: Debe tener al menos 32 caracteres (256 bits) para HS256
# Genera una clave segura: https://www.allkeysgenerator.com/Random/Security-Encryption-Key-Generator.aspx
JWT_KEY="clave_muy_segura_y_larga_para_firmar_tokens_jwt_min_32_chars"

# ==============================================
# CONFIGURACIÓN DE CORREO ELECTRÓNICO
# ==============================================
# Para Gmail, necesitas:
# 1. Activar "Verificación en dos pasos" en tu cuenta
# 2. Generar "Contraseña de aplicación" en:
#    https://myaccount.google.com/apppasswords
# 3. Usar esa contraseña de aplicación aquí (NO tu contraseña normal)

EMAIL_USER="tu_correo@gmail.com"
EMAIL_PASS="tu_contraseña_de_app_gmail"

# ==============================================
# INTELIGENCIA ARTIFICIAL - GOOGLE GEMINI
# ==============================================
# Obtén tu API Key en: https://makersuite.google.com/app/apikey
GEMINI_API_KEY="tu_api_key_de_gemini"
GEMINI_MODEL="gemini-2.0-flash-exp"

# ==============================================
# CONFIGURACIÓN OPCIONAL DEL SERVIDOR
# ==============================================
# Puerto del servidor (opcional, por defecto 8080)
SERVER_PORT="8080"

# Ambiente (development, production)
NODE_ENV="development"

# ==============================================
# INSTRUCCIONES DE CONFIGURACIÓN
# ==============================================
# 1. Copia este archivo:
#    cp .env.example .env
#
# 2. Edita .env con tus valores reales
#
# 3. Asegúrate de que:
#    - MySQL esté corriendo
#    - La base de datos libraryai_db exista
#    - Tu correo de Gmail tenga verificación en dos pasos activada
#    - Hayas generado una contraseña de aplicación para Gmail
#
# 4. Ejecuta el servidor:
#    mvn exec:java -Dexec.mainClass="com.libraryai.backend.App"
#
# ==============================================
# NOTAS DE SEGURIDAD
# ==============================================
# - NUNCA commits este archivo con valores reales
# - Agrega .env a tu .gitignore
# - Usa claves seguras y únicas en producción
# - Rotar las claves periódicamente
# ==============================================
